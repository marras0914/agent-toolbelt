{
  "name": "agent-toolbelt-mcp",
  "mcpName": "io.github.marras0914/agent-toolbelt-mcp",
  "version": "1.0.0",
  "description": "MCP server that exposes Agent Toolbelt API tools to Claude Desktop, Claude Code, VS Code, and other MCP clients",
  "type": "module",
  "bin": {
    "agent-toolbelt-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "dev": "tsx src/index.ts",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "files": ["build", "README.md"],
  "keywords": ["mcp", "claude", "ai", "agent", "tools", "langchain", "llm", "anthropic", "model-context-protocol"],
  "author": "Agent Toolbelt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marras0914/agent-toolbelt"
  },
  "homepage": "https://agent-toolbelt-production.up.railway.app",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0"
  }
}

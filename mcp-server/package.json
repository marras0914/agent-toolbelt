{
  "name": "agent-toolbelt-mcp",
  "version": "1.0.0",
  "description": "MCP server that exposes Agent Toolbelt API tools to Claude Desktop, Claude Code, VS Code, and other MCP clients",
  "type": "module",
  "bin": {
    "agent-toolbelt-mcp": "./build/index.js"
  },
  "scripts": {

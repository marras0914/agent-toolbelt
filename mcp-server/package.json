{
  "name": "agent-toolbelt-mcp",
  "mcpName": "io.github.marras0914/agent-toolbelt-mcp",
  "version": "1.0.9",
  "description": "MCP server that gives Claude real-time stock research — investment thesis, earnings analysis, insider signals, valuation, and bear/bull cases. Plus 20 utility tools.",
  "type": "module",
  "bin": {
    "agent-toolbelt-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "dev": "tsx src/index.ts",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE",
    "scripts"
  ],
  "keywords": [
    "mcp",
    "claude",
    "ai",
    "agent",
    "tools",
    "stock-analysis",
    "stock-research",
    "investing",
    "finance",
    "fundamental-analysis",
    "llm",
    "anthropic",
    "model-context-protocol"
  ],
  "author": "Agent Toolbelt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marras0914/agent-toolbelt"
  },
  "homepage": "https://agent-toolbelt-production.up.railway.app",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0"
  }
}

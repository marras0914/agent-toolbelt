# ============================================
# Agent Toolbelt — Environment Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=production

# API Key Secret (generate with: openssl rand -hex 32)
API_KEY_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Rate Limiting (global)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Usage Tracking
USAGE_TRACKING_ENABLED=true

# Database
DATABASE_PATH=./data/toolbelt.db

# ============================================
# Stock Data APIs
# ============================================
# Polygon.io — https://polygon.io (free tier: unlimited historical, 5 req/min)
POLYGON_API_KEY=

# Finnhub — https://finnhub.io (free tier: 60 req/min)
FINNHUB_API_KEY=

# Financial Modeling Prep — https://financialmodelingprep.com (free tier: 250 req/day)
FMP_API_KEY=

# ============================================
# Stripe Configuration
# ============================================
# 1. Go to https://dashboard.stripe.com
# 2. Create a product called "Agent Toolbelt"
# 3. Create prices: Pro ($10/mo), Starter ($29/mo), Enterprise ($499/mo)
# 4. Copy the price IDs below
# 5. Set up a webhook endpoint pointing to https://yourdomain.com/stripe/webhook
#    with events: checkout.session.completed, customer.subscription.updated,
#    customer.subscription.deleted, invoice.payment_failed

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in Stripe Dashboard → Products).
# Note: the $10 Pro tier's price is read from STRIPE_PRICE_HOBBY (historical
# env var name kept after the hobby→pro rename — see src/tiers.ts).
STRIPE_PRICE_HOBBY=price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ============================================
# Email (Resend — https://resend.com, free tier 3,000/mo)
# ============================================
# Sender domain must be verified in Resend (DNS records in your DNS host).
RESEND_API_KEY=re_...
EMAIL_FROM=hello@agenttoolbelt.live
# Replies route here (the From domain sends but has no inbox).
EMAIL_REPLY_TO=hello@elephanttortoise.com

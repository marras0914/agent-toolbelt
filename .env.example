# ============================================
# Agent Toolbelt — Environment Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=production

# API Key Secret (generate with: openssl rand -hex 32)
API_KEY_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Rate Limiting (global)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Usage Tracking
USAGE_TRACKING_ENABLED=true

# Database
DATABASE_PATH=./data/toolbelt.db

# ============================================
# Stripe Configuration
# ============================================
# 1. Go to https://dashboard.stripe.com
# 2. Create a product called "Agent Toolbelt"
# 3. Create 3 prices: Starter ($29/mo), Pro ($99/mo), Enterprise ($499/mo)
# 4. Copy the price IDs below
# 5. Set up a webhook endpoint pointing to https://yourdomain.com/stripe/webhook
#    with events: checkout.session.completed, customer.subscription.updated,
#    customer.subscription.deleted, invoice.payment_failed

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
